# KernelEye Production Build Configuration
# Copy this file to .env.build and customize all values for your deployment.
# The build-production target reads this file and validates that domains
# have been changed from the placeholder localhost defaults.
#
# cp .env.build.example .env.build
# nano .env.build

# =============================================================================
# API / gRPC Backend
# =============================================================================
KERNELEYE_SERVER=api.example.com:443
KERNELEYE_GRPC_HOST=grpc.example.com

# =============================================================================
# Dashboard / Frontend
# =============================================================================
DASHBOARD_DOMAIN=app.example.com
LANDING_DOMAIN=example.com
INSTALL_DOMAIN=app.example.com

# Frontend build-time variables (derived from domains above)
VITE_API_URL=https://api.example.com/api/v1
VITE_INSTALL_DOMAIN=app.example.com
VITE_GRPC_HOST=grpc.example.com

# =============================================================================
# Docker Registry (optional — override via make REGISTRY=...)
# =============================================================================
# REGISTRY=registry.example.com
# NAMESPACE=kerneleye

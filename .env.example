# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL database password (required)
DB_PASSWORD=

# Full database URL (optional, constructed from DB_PASSWORD if not set)
DATABASE_URL=

# ==========================================
# Redis Configuration
# ==========================================
# Redis URL for rate limiting (optional - required for rate limiting)
# Example: redis://localhost:6379
REDIS_URL=

# ==========================================
# API Configuration
# ==========================================
# JWT secret for authentication (required - generate a strong random string)
JWT_SECRET=

# API key secret for agent authentication (required - generate a strong random string)
API_KEY_SECRET=

# CORS origins (comma-separated list of allowed origins)
# Example: https://app.yourdomain.com,https://yourdomain.com
CORS_ORIGINS=

# ==========================================
# Application URLs
# ==========================================
# Dashboard URL for email links and redirects (required)
# Example: https://app.yourdomain.com
DASHBOARD_URL=

# OAuth redirect URL (must match callback URLs in OAuth providers)
# Example: https://api.yourdomain.com
OAUTH_REDIRECT_URL=

# ==========================================
# Email Configuration (Mailtrap)
# ==========================================
# Mailtrap API token for sending emails
MAILTRAP_API_TOKEN=

# Sender email address
EMAIL_FROM=

# Sender name
EMAIL_FROM_NAME=

# ==========================================
# OAuth Configuration
# ==========================================

# Owner email for self-hosted single-owner access (required for OAuth)
# Only this email can sign in via OAuth. Case-insensitive, whitespace-trimmed.
AUTH_OWNER_EMAIL=

# GitHub OAuth credentials
# Callback URL: {OAUTH_REDIRECT_URL}/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth credentials
# Callback URL: {OAUTH_REDIRECT_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================
# GeoIP Configuration (Optional)
# ==========================================
# MaxMind license key for downloading GeoLite2 databases
# Get free key at: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
MAXMIND_LICENSE_KEY=

# ==========================================
# Frontend Configuration
# ==========================================
# Domain for landing page (required) - WITHOUT https://
# Example: yourdomain.com
LANDING_DOMAIN=

# Domain for dashboard (required) - WITHOUT https://
# Example: app.yourdomain.com
DASHBOARD_DOMAIN=

# Backend API host (required for frontend proxy)
# Example: api.yourdomain.com
BACKEND_HOST=

# Backend API port (required for frontend proxy)
# Example: 443 for HTTPS, 8080 for HTTP
BACKEND_PORT=

# Build-time API URL (optional, defaults to /api/v1)
VITE_API_URL=

# ==========================================
# gRPC TLS Configuration (Backend)
# ==========================================
# Server certificate and key for gRPC TLS encryption
# Leave unset for plaintext (dev only). Required for production.
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=

# mTLS: CA certificate for verifying agent client certificates
# When set, all agents must present a valid client certificate signed by this CA.
GRPC_MTLS_CA_FILE=

# ==========================================
# Command Signing Configuration
# ==========================================
# Shared HMAC key for signing remediation commands (block/unblock/rate-limit).
# Must be identical on both agent and backend.
# Generate with: openssl rand -base64 32
CMD_SIGNING_KEY=

# ==========================================
# Agent Configuration (for local testing)
# ==========================================
# API key for agent authentication
KERNELEYE_API_KEY=

# Backend server address for agent
KERNELEYE_SERVER=

# Agent TLS configuration
# CA certificate file for backend verification (required for production)
KERNELEYE_TLS_CA_FILE=
# Agent client certificate for mTLS
KERNELEYE_TLS_CERT_FILE=
# Agent client private key for mTLS
KERNELEYE_TLS_KEY_FILE=
# Override TLS server name for hostname verification
KERNELEYE_TLS_SERVER_NAME=

# Path to the audit log file
KERNELEYE_AUDIT_LOG=

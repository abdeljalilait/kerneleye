# Environment Configuration
DATABASE_URL=postgres://kerneleye:changeme@localhost:5432/kerneleye?sslmode=disable
DB_PASSWORD=changeme

# API Configuration
PORT=8080
GRPC_PORT=9091
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.kerneleye.cloud
JWT_SECRET=dev-secret-change-in-production
API_KEY_SECRET=change-in-production

# Dashboard URL (for email links)
DASHBOARD_URL=https://app.kerneleye.cloud

# Email Configuration (Mailtrap)
MAILTRAP_API_TOKEN=your-mailtrap-api-token
EMAIL_FROM=noreply@kerneleye.cloud
EMAIL_FROM_NAME=KernelEye

# Polar Payment Integration
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_ACCESS_TOKEN=polar_at_xxx

# Agent Configuration (for testing)
KERNELEYE_API_KEY=demo-key
KERNELEYE_SERVER=localhost:8080

# ==========================================
# Frontend Docker Image Configuration
# ==========================================

# Domain Configuration
LANDING_DOMAIN=kerneleye.cloud
DASHBOARD_DOMAIN=app.kerneleye.cloud

# Backend API Configuration (for frontend proxy)
# Production: api.kerneleye.cloud
# Development: kerneleyeapi.hakiware.com
BACKEND_HOST=api.kerneleye.cloud
BACKEND_PORT=443

# Build-time API URL (for dashboard build)
VITE_API_URL=/api/v1
